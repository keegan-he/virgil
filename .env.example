# Discord bot token — get from https://discord.com/developers/applications
DISCORD_BOT_TOKEN=your_discord_bot_token_here

# That's it! Just the Discord token.
# Notifications auto-detect your DM channel — no user ID needed.
# Weather uses wttr.in (free, no auth)
# GitHub uses gh CLI (already authenticated)
# Spotify scrapes public pages (no credentials)
